# API auth — clients (including the HappyRobot workflow) must send this as `X-API-Key`
API_KEY=change-me-to-a-long-random-string

# FMCSA QCMobile API web key. Request one at https://mobile.fmcsa.dot.gov/QCDevsite/
# When unset, /v1/carriers/verify runs in mock mode (alternates eligible/not-eligible by MC parity).
FMCSA_WEB_KEY=your-fmcsa-web-key

# SQLite file path inside the container
DATABASE_URL=sqlite:////data/app.db

# Where the dashboard reads from. In docker-compose this is the api service name.
API_BASE_URL=http://api:8000
